import React, { useState } from 'react';
import { useApp } from './context/AppContext';
import Sidebar from './components/Sidebar';
import { AdminDashboard, LitigatorDashboard, DetailModal } from './components/Dashboards';
import { Card, Button } from './components/ui';

const LoginView: React.FC = () => {
    const { users, setCurrentUser, setCurrentPage } = useApp();
    const [formData, setFormData] = useState({ email: '', password: '' });
    const [error, setError] = useState('');

    const handleLogin = (e: React.FormEvent) => {
        e.preventDefault();
        const user = users.find(u => u.email === formData.email && u.password === formData.password);
        
        if (!user) {
            setError('Invalid email or password.');
            return;
        }
        if (!user.isActive) {
            setError('Your account is pending Admin approval.');
            return;
        }

        setCurrentUser(user);
        setCurrentPage(user.role + '-dashboard');
    };

    return (
        <div className="min-h-screen bg-navy flex items-center justify-center p-4">
            <Card className="w-full max-w-md p-8 border-none shadow-2xl">
                <div className="flex flex-col items-center mb-10">
                    <div className="h-16 w-16 bg-navy text-gold rounded-2xl flex items-center justify-center text-3xl mb-4 shadow-lg border border-gold/20">⚖️</div>
                    <h1 className="text-3xl font-black text-navy tracking-tighter uppercase">LexPortal</h1>
                    <p className="text-slate-400 font-bold text-[10px] uppercase tracking-[0.3em] mt-2">Enterprise Legal Suite</p>
                </div>

                {error && <p className="text-red-500 text-xs font-bold mb-6 text-center bg-red-50 p-3 rounded-lg border border-red-100 uppercase tracking-widest">{error}</p>}

                <form onSubmit={handleLogin} className="space-y-6">
                    <div className="space-y-2">
                        <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Secure Email</label>
                        <input 
                            type="email" 
                            required
                            placeholder="counsel@lexportal.com"
                            className="w-full p-4 bg-slate-50 border-2 border-slate-100 rounded-xl focus:border-gold outline-none transition-all font-bold text-navy"
                            value={formData.email}
                            onChange={e => setFormData({...formData, email: e.target.value})}
                        />
                    </div>
                    <div className="space-y-2">
                        <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Access Token</label>
                        <input 
                            type="password" 
                            required
                            placeholder="••••••••"
                            className="w-full p-4 bg-slate-50 border-2 border-slate-100 rounded-xl focus:border-gold outline-none transition-all font-bold text-navy"
                            value={formData.password}
                            onChange={e => setFormData({...formData, password: e.target.value})}
                        />
                    </div>
                    <Button type="submit" className="w-full py-4 text-sm" variant="accent">Authorize Access →</Button>
                </form>
                
                <div className="mt-8 pt-6 border-t border-slate-100 text-center">
                   <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                       Protected by AES-256 Encryption
                   </p>
                </div>
            </Card>
        </div>
    );
};

const App: React.FC = () => {
    const { currentPage, currentUser } = useApp();
    
    if (currentPage === 'login' || !currentUser) {
        return <LoginView />;
    }

    return (
        <div className="flex h-screen bg-grey-light overflow-hidden font-inter pt-0">
            <Sidebar />
            <div className="flex-1 flex flex-col min-w-0 overflow-hidden relative">
                {currentPage === 'admin-dashboard' && <AdminDashboard />}
                {currentPage === 'litigator-dashboard' && <LitigatorDashboard />}
                {/* Accountant and Advisory would be added similarly */}
                {['accountant-dashboard', 'advisory-dashboard'].includes(currentPage) && (
                    <div className="flex-1 flex items-center justify-center">
                        <div className="text-center">
                            <span className="text-4xl mb-4 block">🚧</span>
                            <h2 className="text-xl font-black text-navy uppercase">{currentPage.replace('-', ' ')}</h2>
                            <p className="text-slate-400 text-sm mt-2">Module modularization in progress...</p>
                        </div>
                    </div>
                )}
                <DetailModal />
            </div>
        </div>
    );
}

export default App;
