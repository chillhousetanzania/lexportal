import React, { createContext, useState, useContext, ReactNode } from 'react';

// --- Types ---
export interface User {
    id: number;
    name: string;
    email: string;
    password?: string;
    role: 'admin' | 'accountant' | 'litigator' | 'advisory';
    isActive: boolean;
    canShareDocuments: boolean;
}

export interface Case {
    id: number;
    title: string;
    clientId: number;
    litigatorId: number;
    status: 'new' | 'ongoing' | 'decided' | 'research';
    notes: string;
    date: string;
}

export interface FinancialRecord {
    id: number;
    accountantId: number;
    newCases: number;
    amountPaid: number;
    paymentStatus: 'Paid' | 'Partial' | 'Pending';
    amountRemaining: number;
    date: string;
}

export interface Report {
    id: number;
    title: string;
    litigatorName: string;
    date: string;
    type: string;
    content: string;
}

interface AppContextType {
    users: User[];
    setUsers: React.Dispatch<React.SetStateAction<User[]>>;
    cases: Case[];
    setCases: React.Dispatch<React.SetStateAction<Case[]>>;
    financialRecords: FinancialRecord[];
    setFinancialRecords: React.Dispatch<React.SetStateAction<FinancialRecord[]>>;
    reports: Report[];
    setReports: React.Dispatch<React.SetStateAction<Report[]>>;
    globalSharingEnabled: boolean;
    setGlobalSharingEnabled: React.Dispatch<React.SetStateAction<boolean>>;
    currentUser: User | null;
    setCurrentUser: React.Dispatch<React.SetStateAction<User | null>>;
    currentPage: string;
    setCurrentPage: React.Dispatch<React.SetStateAction<string>>;
    activeSection: string;
    setActiveSection: React.Dispatch<React.SetStateAction<string>>;
    selectedItem: any;
    setSelectedItem: React.Dispatch<React.SetStateAction<any>>;
    logout: () => void;
}

